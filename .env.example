# TaxFlow environment variables — copy to .env (or export in your shell) and fill in real values.
# All variables have safe local defaults in backend/src/main/resources/application.yml.

# --- Database (PostgreSQL 15+) ---
DB_URL=jdbc:postgresql://localhost:5432/taxflow
DB_USERNAME=taxflow
DB_PASSWORD=taxflow

# --- JWT (generate a secure 64+ char string for production) ---
JWT_SECRET=change-me-to-a-long-random-secret-of-at-least-64-characters-please
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=14

# --- CORS (comma separated origins of the frontend) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Rate limiting ---
RATE_LIMIT_PER_MINUTE=160

# --- Local file storage (receipts, documents) ---
STORAGE_PATH=./storage

# --- Server ---
SERVER_PORT=8080
